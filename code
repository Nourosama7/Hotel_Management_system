double calculateBill(double basePrice, double additionalCharges[], int n) {
 if (n == 0) return basePrice;
 return calculateBill(basePrice + additionalCharges[n - 1], additionalCharges, n - 1);
}
// Function to generate bill
void generateBill() {
 double basePrice = 200.0;
 double additionalCharges[] = {20.0, 30.0, 15.0};
 int n = sizeof(additionalCharges) / sizeof(additionalCharges[0]);
 double total = calculateBill(basePrice, additionalCharges, n);
 cout << "Total Bill: $" << total << endl;
}
//***********************************************************************************
*******************************************************
// Function to apply discount
void applyDiscount() {
 double basePrice;
 int stayDays;
 char loyaltyResponse;
 cout << "Enter the base price of the room: $";
 cin >> basePrice;
 cout << "Enter the number of days the customer is staying: ";
 cin >> stayDays;
 if (stayDays <= 1) {
 cout << "Invalid number of days.\n";
 return;
 }
 cout << "Is the customer a loyal customer? (y/n): ";
 cin >> loyaltyResponse;
 bool isLoyalCustomer = (loyaltyResponse == 'y' || loyaltyResponse == 'Y');
 double discount = 0.0;
 if (stayDays > 5 && stayDays <= 10) discount += 10.0;
 else if (stayDays > 10) discount += 15.0;
 if (isLoyalCustomer) discount += 5.0;
 double finalBill = basePrice * (1 - discount / 100);
 cout << "Final bill after discount: $" << finalBill << endl;
}
