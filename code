// Function to manage reservation history
void manageReservations() {
 int choice;
 cout << "1. Add Reservation\n2. Cancel Last Reservation\nEnter your choice: ";
 cin >> choice;
 if (choice == 1) {
 string name;
 cout << "Enter the customer name: ";
 cin.ignore();
 getline(cin, name);
 reservationHistory.push(name);
 cout << "Reservation added for " << name << ".\n";
 } else if (choice == 2) {
 if (!reservationHistory.isEmpty()) {
 cout << "Reservation canceled for " << reservationHistory.top() << ".\n";
 reservationHistory.pop();
 } else {
 cout << "No reservations to cancel.\n";
 }
 } else {
 cout << "this choice isn't Available.\n";
 }
}
//***********************************************************************************
****************************************************
void manageServiceQueue() {
 int choice;
 cout << "1. Add Service Request\n2. Process Service Request\nEnter your choice: ";
 cin >> choice;
 if (choice == 1) {
 string request;
 cout << "Enter the service request: ";
 cin.ignore();
 getline(cin, request);
 serviceQueue.enqueue(request); //Add
 cout << "Service request added: " << request << ".\n";
 } else if (choice == 2) {
 if (!serviceQueue.isEmpty()) {
 cout << "Processing service request: " << serviceQueue.front() << ".\n";
 serviceQueue.dequeue();
 } else {
 cout << "No service requests in the queue.\n";
 }
 } else {
 cout << "This choice isn't Available.\n";
 }
}
