const int TOTAL_ROOMS = 10;
struct Room {
 int roomNumber;
 string roomType;
 bool isAvailable;
 double price;
};
Room hotelRooms[TOTAL_ROOMS];
Stack<string> reservationHistory; //q
queue<string> serviceQueue;
// Function to initialize rooms
void initializeRooms() {
 for (int i = 0; i < TOTAL_ROOMS; i++) {
 hotelRooms[i] = {i + 1, (i % 2 == 0 ? "Single" : "Double"), true, (i % 2 == 0 ? 100.0 : 200.0)};
 }
}
void displayRooms() {
 cout << "Room Number\tType\tAvailability\tPrice\n";
 for (int i = 0; i < TOTAL_ROOMS; i++) {
 cout << hotelRooms[i].roomNumber << "\t\t" << hotelRooms[i].roomType << "\t"
 << (hotelRooms[i].isAvailable ? "Available" : "Booked") << "\t\t$" << hotelRooms[i].price << endl;
 }
}
//***********************************************************************************
****************************************************
// Function to book a room
void bookRoom() {
 int roomNumber;
 cout << "Enter the room number to book: ";
 cin >> roomNumber;
 if (roomNumber < 1 || roomNumber > TOTAL_ROOMS) {
 cout << "Room isn't Available.\n";
 return;
 }
 if (!hotelRooms[roomNumber - 1].isAvailable) {
 cout << "Room " << roomNumber << " is already booked.\n";
 return;
 }
 hotelRooms[roomNumber - 1].isAvailable = false;
 cout << "Room " << roomNumber << " successfully booked.\n";
}
